# AI-Platform Environment Configuration
# Copy to .env and adjust values

# Gateway Configuration
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
WORKERS=1
DEBUG=False
LOG_LEVEL=INFO

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen:7b-coder
OLLAMA_TIMEOUT=300

# Model Parameters (Generation Defaults)
TEMPERATURE=0.7
TOP_P=0.9
MAX_TOKENS=2048

# Cache Configuration
CACHE_TYPE=file
CACHE_DIR=./data/cache
CACHE_MAX_SIZE=1000
CACHE_TTL=86400
# Cosine-similarity cutoff for semantic cache hits. 0.95 = conservative
# (near-duplicates only); lower values cache more aggressively.
SEMANTIC_SIMILARITY_THRESHOLD=0.95

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Logging
LOG_DIR=./data/logs
LOG_FILE=ai_gateway.log
LOG_FORMAT=json

# Security (Phase 4)
# JWT_SECRET=your-secret-key-here
# JWT_ALGORITHM=HS256
# API_KEY_HEADER=X-API-Key

# Database (Phase 3 - Optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_platform

# Redis (Phase 2 - Optional)
# REDIS_URL=redis://localhost:6379/0

# Monitoring
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=8001

# Feature Flags
ENABLE_CACHE=True
ENABLE_SEMANTIC_CACHE=True
ENABLE_METRICS=True
ENABLE_AUDIT_LOG=True
