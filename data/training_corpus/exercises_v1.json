  "exercises": [
    {
      "id": "arch_junior_001",
      "level": "junior",
      "category": "architecture",
      "title": "Explain MVC Pattern",
      "description": "Explain the Model-View-Controller pattern. What is the responsibility of each layer? Provide a simple example with code.",
      "expected_patterns": ["mvc", "model", "view", "controller", "separation of concerns"],
      "auto_eval_regex": [
        "(?i)model.*data|database",
        "(?i)view.*presentation|template",
        "(?i)controller.*request|input"
      ],
      "manual_eval_required": false
    },
    {
