# Training Configuration
# Copy this file to .env.training.local and customize

# Paths (auto-detected)
# CORPUS_DIR=./data/training_corpus
# EXERCISES_FILE=./data/training_corpus/exercises_v1.json
# TRAINING_LOGS_DIR=./data/training_logs

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=neural-chat
OLLAMA_TIMEOUT=300

# Generation Parameters
GENERATION_TEMPERATURE=0.7
GENERATION_TOP_P=0.9
GENERATION_MAX_TOKENS=2048

# Training Mode
# Options: "local_only" (free, lower quality feedback) or "hybrid" (uses Claude API)
TRAINING_MODE=local_only

# Checkpoint Interval (minutes)
# local_only: ignored
# hybrid: how often to send checkpoint to Claude (480 = 8 hours = ~3-5 checkpoints/day = ~$0.15/day with Haiku)
CHECKPOINT_INTERVAL_MINUTES=480

# Training Duration
TRAINING_DURATION_HOURS=12

# Claude API (required if TRAINING_MODE=hybrid)
# Get your API key from: https://console.anthropic.com/
# Leave empty for local_only mode
ANTHROPIC_API_KEY=

# Claude Model (for hybrid mode)
# Budget-friendly: claude-haiku-4-5-20251001 (fast, cheap)
# Better quality: claude-sonnet-4-6 (medium cost)
# Best quality: claude-opus-4-8 (expensive)
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_CHECKPOINT_MAX_TOKENS=1500

# Quality Thresholds
QUALITY_SCORE_THRESHOLD=6.0
PATTERN_MATCH_MIN_PERCENT=0.6
REGEX_MATCH_MIN_PERCENT=0.5

# Logging
LOG_LEVEL=INFO

# Advanced: Prompt Caching (reduces Claude API costs by 90%)
# Only applicable with hybrid mode + Anthropic API
# Automatically enabled
